<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="Ink950Color">#FF050914</Color>
  <Color x:Key="Ink900Color">#FF0A1220</Color>
  <Color x:Key="Ink850Color">#FF0E1B31</Color>
  <Color x:Key="Slate500Color">#FF6F83A8</Color>
  <Color x:Key="Slate300Color">#FFC7D5F5</Color>
  <Color x:Key="Blue500Color">#FF48A8FF</Color>
  <Color x:Key="Blue300Color">#FF9CD2FF</Color>
  <Color x:Key="Blue200Color">#FFD5E8FF</Color>
  <Color x:Key="SuccessColor">#FF5FD2A2</Color>

  <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource Ink900Color}" />
  <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF1D3050" />
  <SolidColorBrush x:Key="PanelSectionBrush" Color="#D9111C30" />
  <SolidColorBrush x:Key="PrimaryTextBrush" Color="White" />
  <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource Slate300Color}" />
  <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource Slate500Color}" />
  <SolidColorBrush x:Key="Blue200Brush" Color="{StaticResource Blue200Color}" />
  <SolidColorBrush x:Key="CursorFillBrush" Color="{StaticResource Blue500Color}" />
  <SolidColorBrush x:Key="CursorStrokeBrush" Color="{StaticResource Blue200Color}" />
  <SolidColorBrush x:Key="OverlayBubbleBrush" Color="#EE0D1628" />
  <SolidColorBrush x:Key="PrimaryButtonBrush" Color="{StaticResource Blue500Color}" />
  <SolidColorBrush x:Key="PrimaryButtonHoverBrush" Color="#FF6AB7FF" />
  <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#FF17253E" />
  <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#FF1D3152" />
  <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FF0C1628" />
  <SolidColorBrush x:Key="InputBorderBrush" Color="#FF243A60" />

  <LinearGradientBrush x:Key="PanelBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource Ink850Color}" Offset="0" />
    <GradientStop Color="{StaticResource Ink950Color}" Offset="1" />
  </LinearGradientBrush>

  <Style TargetType="Window">
    <Setter Property="FontFamily" Value="Bahnschrift, Segoe UI" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="ButtonBorder"
                  Background="{TemplateBinding Background}"
                  CornerRadius="16">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ButtonBorder"
                      Property="Background"
                      Value="{StaticResource SecondaryButtonHoverBrush}" />
            </Trigger>
            <Trigger Property="Tag" Value="primary">
              <Setter TargetName="ButtonBorder"
                      Property="Background"
                      Value="{StaticResource PrimaryButtonBrush}" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="Tag" Value="primary" />
              </MultiTrigger.Conditions>
              <Setter TargetName="ButtonBorder"
                      Property="Background"
                      Value="{StaticResource PrimaryButtonHoverBrush}" />
            </MultiTrigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="CaretBrush" Value="White" />
  </Style>

  <Style TargetType="ComboBox">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="12,6" />
  </Style>
</ResourceDictionary>
