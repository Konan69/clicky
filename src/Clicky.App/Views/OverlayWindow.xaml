<Window x:Class="Clicky.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None">
  <Grid IsHitTestVisible="False">
    <Border Margin="{Binding CursorMargin}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
      <StackPanel Orientation="Horizontal">
        <Grid Width="30" Height="30" VerticalAlignment="Top">
          <Ellipse Fill="{StaticResource CursorFillBrush}"
                   Stroke="{StaticResource CursorStrokeBrush}"
                   StrokeThickness="2" />
          <Ellipse Width="8"
                   Height="8"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Fill="White" />
        </Grid>

        <Border MaxWidth="440"
                Margin="16,0,0,0"
                Padding="18"
                Background="{StaticResource OverlayBubbleBrush}"
                CornerRadius="24">
          <Border.Effect>
            <DropShadowEffect BlurRadius="30"
                              Opacity="0.35"
                              ShadowDepth="14"
                              Color="#FF020611" />
          </Border.Effect>

          <StackPanel>
            <TextBlock Foreground="{StaticResource Blue200Brush}"
                       FontWeight="SemiBold"
                       Text="{Binding BubbleTitleText}" />
            <TextBlock Margin="0,10,0,0"
                       Foreground="{StaticResource PrimaryTextBrush}"
                       Text="{Binding BubbleBodyText}"
                       TextWrapping="Wrap" />
            <ProgressBar Margin="0,12,0,0"
                         Height="6"
                         Minimum="0"
                         Maximum="1"
                         Value="{Binding CurrentAudioLevel}"
                         Background="#66243A60"
                         Foreground="{StaticResource CursorFillBrush}" />
            <TextBlock Margin="0,12,0,0"
                       Foreground="{StaticResource MutedTextBrush}"
                       Text="{Binding StatusText}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>
  </Grid>
</Window>
